rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Config globale (clé API fondateur) — lecture pour tous, écriture admin uniquement
    match /config/{docId} {
      allow read: if request.auth != null;
    }

    // Profils utilisateurs — chacun lit/écrit le sien
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Company — création par tout utilisateur authentifié, lecture/écriture par membres
    match /companies/{companyId} {
      allow create: if request.auth != null;
      allow read: if isCompanyMember(companyId);
      allow update, delete: if isCompanyManager(companyId);

      // Invitations — lisibles par tout utilisateur authentifié (pour rejoindre)
      match /invitations/{email} {
        allow read: if request.auth != null;
        allow write: if isCompanyMember(companyId);
        allow delete: if request.auth != null;
      }

      // Sous-collections data (drivers, trucks, tours, etc.)
      match /{collection}/{docId} {
        allow read, write: if isCompanyMember(companyId);
      }
    }

    function isCompanyMember(companyId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId;
    }

    function isCompanyManager(companyId) {
      return isCompanyMember(companyId) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }
  }
}
